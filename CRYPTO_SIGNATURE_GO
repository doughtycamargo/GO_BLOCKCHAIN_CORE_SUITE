package main

import (
	"crypto/ecdsa"
	"crypto/elliptic"
	"crypto/rand"
	"crypto/sha256"
	"fmt"
	"math/big"
)

func SignData(privateKey *ecdsa.PrivateKey, data []byte) (*big.Int, *big.Int, error) {
	hash := sha256.Sum256(data)
	return ecdsa.Sign(rand.Reader, privateKey, hash[:])
}

func VerifySignature(publicKey *ecdsa.PublicKey, data []byte, r, s *big.Int) bool {
	hash := sha256.Sum256(data)
	return ecdsa.Verify(publicKey, hash[:], r, s)
}

func main() {
	private, _ := ecdsa.GenerateKey(elliptic.P256(), rand.Reader)
	data := []byte("blockchain transaction")
	r, s, _ := SignData(private, data)
	valid := VerifySignature(&private.PublicKey, data, r, s)
	fmt.Println("Signature Valid:", valid)
}
