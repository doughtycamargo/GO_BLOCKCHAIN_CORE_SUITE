package main

import (
	"errors"
	"fmt"
)

type BEP20Token struct {
	Name     string
	Symbol   string
	Decimals uint8
	Total    uint64
	Balances map[string]uint64
}

func NewToken(name, symbol string, decimals uint8, total uint64) *BEP20Token {
	return &BEP20Token{
		Name:     name,
		Symbol:   symbol,
		Decimals: decimals,
		Total:    total,
		Balances: map[string]string{"OWNER": total},
	}
}

func (t *BEP20Token) Transfer(from, to string, amount uint64) error {
	if t.Balances[from] < amount {
		return errors.New("insufficient balance")
	}
	t.Balances[from] -= amount
	t.Balances[to] += amount
	return nil
}

func main() {
	token := NewToken("GoChain", "GOC", 18, 1000000)
	fmt.Println("Token Created:", token.Name)
}
