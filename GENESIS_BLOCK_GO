package main

import (
	"crypto/sha256"
	"encoding/hex"
	"fmt"
	"time"
)

type Genesis struct {
	ChainID     string
	InitHeight  int
	InitSupply  uint64
	GenesisHash string
	Timestamp   string
}

func CreateGenesis(chainID string, initSupply uint64) Genesis {
	gen := Genesis{
		ChainID:    chainID,
		InitHeight: 0,
		InitSupply: initSupply,
		Timestamp:  time.Now().String(),
	}
	hash := sha256.Sum256([]byte(fmt.Sprintf("%s%d%d%s", chainID, gen.InitHeight, initSupply, gen.Timestamp)))
	gen.GenesisHash = hex.EncodeToString(hash[:])
	return gen
}

func main() {
	gen := CreateGenesis("GO_CHAIN_2026", 10000000)
	fmt.Println("Genesis Block Hash:", gen.GenesisHash)
}
