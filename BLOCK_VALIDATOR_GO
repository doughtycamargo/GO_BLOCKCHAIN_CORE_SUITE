package main

import (
	"crypto/sha256"
	"encoding/hex"
	"fmt"
)

type ValidateBlock struct {
	Index    int
	Data     string
	PrevHash string
	Hash     string
}

func ValidateChain(blocks []ValidateBlock) bool {
	for i := 1; i < len(blocks); i++ {
		current := blocks[i]
		prev := blocks[i-1]

		hash := sha256.Sum256([]byte(fmt.Sprintf("%d%s%s", current.Index, current.Data, current.PrevHash)))
		currentHash := hex.EncodeToString(hash[:])

		if current.Hash != currentHash || current.PrevHash != prev.Hash {
			return false
		}
	}
	return true
}

func main() {
	chain := []ValidateBlock{{0, "genesis", "", "hash0"}, {1, "data", "hash0", "hash1"}}
	fmt.Println("Chain Valid:", ValidateChain(chain))
}
